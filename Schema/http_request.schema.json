{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PrincetonAfeez/Web-Server/Schema/http_request.schema.json",
  "title": "HTTP/1.1 Parsed Request",
  "description": "Contract for a parsed HTTP request after bytes have been read from the TCP connection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "method",
    "target",
    "version",
    "headers",
    "body_size"
  ],
  "properties": {
    "method": {
      "type": "string",
      "pattern": "^[A-Z!#$%&'*+.^_`|~-]+$",
      "examples": [
        "GET",
        "POST",
        "HEAD"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "/",
        "/_pyserve/stats",
        "/static/app.css"
      ]
    },
    "version": {
      "type": "string",
      "enum": [
        "HTTP/1.0",
        "HTTP/1.1"
      ]
    },
    "headers": {
      "type": "object",
      "description": "HTTP header map. Header names are case-insensitive; values are serialized strings.",
      "propertyNames": {
        "pattern": "^[!#$%&'*+.^_`|~0-9A-Za-z-]+$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "body_size": {
      "type": "integer",
      "minimum": 0
    },
    "client": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    },
    "keep_alive": {
      "type": "boolean",
      "description": "Whether the connection is eligible to remain open after this request."
    }
  },
  "examples": [
    {
      "method": "GET",
      "target": "/",
      "version": "HTTP/1.1",
      "headers": {
        "Host": "127.0.0.1:8000"
      },
      "body_size": 0,
      "keep_alive": true
    }
  ]
}
